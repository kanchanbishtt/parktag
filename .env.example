PORT=4000
APP_ENV=dev

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=wavetag
MONGODB_COLLECTION_PREFIX=dev_

# Exotel (voice calls / masked calling)
EXOTEL_API_BASE_URL=https://api.exotel.com
EXOTEL_ACCOUNT_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_CALLER_ID=
EXOTEL_STATUS_CALLBACK_URL=

# Meta WhatsApp Cloud API (direct — used for all WhatsApp messages)
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_ACCESS_TOKEN=

# Exotel SMS (optional)
EXOTEL_SMS_SENDER_ID=
EXOTEL_SMS_DLT_ENTITY_ID=
EXOTEL_SMS_TEMPLATE_ID=
